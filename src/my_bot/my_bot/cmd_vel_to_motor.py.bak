#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
import serial
import time
import math


def clamp(x, lo, hi):
    return max(lo, min(hi, x))


class CmdVelToMotor(Node):
    def __init__(self):
        super().__init__('cmd_vel_to_motor')

        # ---------- Parameters ----------
        self.declare_parameter('port', '/dev/arduino')
        self.declare_parameter('baud', 115200)

        # ล้อซ้ายช้า -> เพิ่ม gain ฝั่งซ้าย
        self.declare_parameter('left_gain', 1.80)
        self.declare_parameter('right_gain', 1.00)

        # PWM
        self.declare_parameter('pwm_min', 150)   # ให้มอเตอร์ออกตัวได้จริงกับ L298N
        self.declare_parameter('pwm_max', 255)

        # จำกัดความเร็วที่ถือว่า "เต็มสเกล" เพื่อ map เป็น PWM
        self.declare_parameter('max_linear', 0.25)   # m/s (ปรับได้)
        self.declare_parameter('max_angular', 1.2)   # rad/s (ปรับได้)

        # ถ้าทิศจอยกลับด้าน ให้สลับที่นี่แทนการสลับสาย
        self.declare_parameter('invert_left', False)
        self.declare_parameter('invert_right', False)

        # ---------- Load ----------
        self.port = self.get_parameter('port').value
        self.baud = self.get_parameter('baud').value

        self.left_gain = float(self.get_parameter('left_gain').value)
        self.right_gain = float(self.get_parameter('right_gain').value)

        self.pwm_min = int(self.get_parameter('pwm_min').value)
        self.pwm_max = int(self.get_parameter('pwm_max').value)

        self.max_linear = float(self.get_parameter('max_linear').value)
        self.max_angular = float(self.get_parameter('max_angular').value)

        self.invert_left = bool(self.get_parameter('invert_left').value)
        self.invert_right = bool(self.get_parameter('invert_right').value)

        # ---------- Serial ----------
        self.ser = serial.Serial(self.port, self.baud, timeout=0.1)
        time.sleep(2.0)
        self.get_logger().info(f'Connected to Arduino: {self.port}')

        # ---------- ROS ----------
        self.sub = self.create_subscription(Twist, '/cmd_vel', self.cmd_callback, 10)

    def speed_to_pwm(self, s_norm: float, gain: float, invert: bool) -> int:
        """
        s_norm: normalized speed in [-1, 1]
        """
        s_norm = clamp(s_norm, -1.0, 1.0) * gain
        s_norm = clamp(s_norm, -1.0, 1.0)

        if invert:
            s_norm *= -1.0

        if abs(s_norm) < 1e-4:
            return 0

        # map magnitude -> [pwm_min .. pwm_max]
        mag = abs(s_norm)
        pwm = int(self.pwm_min + mag * (self.pwm_max - self.pwm_min))
        pwm = clamp(pwm, self.pwm_min, self.pwm_max)

        return pwm if s_norm > 0 else -pwm

    def cmd_callback(self, msg: Twist):
        v = float(msg.linear.x)
        w = float(msg.angular.z)

        # normalize by max limits
        v_n = clamp(v / self.max_linear, -1.0, 1.0)
        w_n = clamp(w / self.max_angular, -1.0, 1.0)

        # simple diff mix (normalized)
        left_n = v_n - w_n
        right_n = v_n + w_n

        # normalize again to keep within [-1,1]
        m = max(1.0, abs(left_n), abs(right_n))
        left_n /= m
        right_n /= m

        left_pwm = self.speed_to_pwm(left_n, self.left_gain, self.invert_left)
        right_pwm = self.speed_to_pwm(right_n, self.right_gain, self.invert_right)

        # IMPORTANT: Arduino ของคุณใช้ CR เป็นตัวจบคำสั่ง
        cmd = f"m {left_pwm} {right_pwm}\r"
        try:
            self.ser.write(cmd.encode())
        except Exception as e:
            self.get_logger().warn(f"Serial write failed: {e}")
            return

        # debug ให้เห็น v,w และ PWM
        self.get_logger().info(
            f"cmd_vel v={v:.3f} w={w:.3f} | norm L={left_n:.2f} R={right_n:.2f} | SEND: {left_pwm} {right_pwm}"
        )


def main():
    rclpy.init()
    node = CmdVelToMotor()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()

