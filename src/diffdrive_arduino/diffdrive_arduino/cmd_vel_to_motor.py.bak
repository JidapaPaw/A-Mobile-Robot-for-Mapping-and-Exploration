#!/usr/bin/env python3
import time
import serial
import rclpy
from rclpy.node import Node

from serial_motor_demo_msgs.msg import MotorCommand


class CmdVelToMotor(Node):
    def __init__(self):
        super().__init__('cmd_vel_to_motor')

        # ---- parameters ----
        self.declare_parameter('port', '/dev/arduino')
        self.declare_parameter('baud', 115200)
        self.declare_parameter('topic', '/motor_cmd')
        self.declare_parameter('watchdog_timeout', 0.3)  # seconds
        self.declare_parameter('tx_rate_hz', 20.0)        # periodic resend

        self.port = self.get_parameter('port').value
        self.baud = int(self.get_parameter('baud').value)
        self.topic = self.get_parameter('topic').value
        self.watchdog_timeout = float(self.get_parameter('watchdog_timeout').value)
        self.tx_rate_hz = float(self.get_parameter('tx_rate_hz').value)

        # ---- serial open ----
        self.ser = serial.Serial(self.port, self.baud, timeout=0.05)
        self.get_logger().info(f'Opening serial port={self.port} baud={self.baud}')

        # ---- state ----
        self.last_rx_time = self.get_clock().now()
        self.last_cmd = MotorCommand()
        self.last_cmd.left = 0
        self.last_cmd.right = 0

        # ---- ROS ----
        self.sub = self.create_subscription(
            MotorCommand,
            self.topic,
            self.on_cmd,
            10
        )
        self.get_logger().info(f'Subscribed to {self.topic} (MotorCommand)')

        # periodic TX + watchdog
        period = 1.0 / self.tx_rate_hz if self.tx_rate_hz > 0 else 0.05
        self.timer = self.create_timer(period, self.on_timer)

    def on_cmd(self, msg: MotorCommand):
        self.last_cmd = msg
        self.last_rx_time = self.get_clock().now()

    def _write_serial(self, left: int, right: int):
        # ส่งรูปแบบที่ Arduino parser รับชัวร์: "L=.. R=..\n"
        line = f"L={int(left)} R={int(right)}\n"
        try:
            self.ser.write(line.encode('ascii', errors='ignore'))
        except Exception as e:
            self.get_logger().error(f"Serial write failed: {e}")

    def on_timer(self):
        # watchdog: ถ้าเงียบเกิน timeout -> ส่ง stop
        dt = (self.get_clock().now() - self.last_rx_time).nanoseconds / 1e9
        if dt > self.watchdog_timeout:
            self._write_serial(0, 0)
            return

        # ปกติ: ส่งคำสั่งล่าสุดซ้ำเรื่อย ๆ (กันหลุดเฟรม)
        self._write_serial(self.last_cmd.left, self.last_cmd.right)

    def send_stop_and_close(self):
        # ส่ง stop ซ้ำ 3 ครั้ง กันหลุด
        try:
            for _ in range(3):
                self._write_serial(0, 0)
                time.sleep(0.03)
        finally:
            try:
                if self.ser and self.ser.is_open:
                    self.ser.close()
            except Exception:
                pass


def main():
    rclpy.init()
    node = CmdVelToMotor()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.get_logger().warn("Shutdown: sending STOP (0,0)")
        node.send_stop_and_close()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
